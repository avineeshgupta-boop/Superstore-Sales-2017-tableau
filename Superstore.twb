            </column>
            <column caption='Metric Parameter' datatype='real' name='[Calculation_1649881392713735]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;Sales&quot; THEN SUM([Sales])&#13;&#10;WHEN &quot;Profit&quot; THEN SUM([Profit])&#13;&#10;WHEN &quot;Orders&quot; THEN COUNT([Order ID])&#13;&#10;END' />
            </column>
            <column caption='% Diff Sales' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[Calculation_1649881485783048]' role='measure' type='quantitative'>
