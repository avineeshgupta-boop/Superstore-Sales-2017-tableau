          <datasource-dependencies datasource='Parameters'>
            <column caption='Metric Selector' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Profit&quot;'>
              <calculation class='tableau' formula='&quot;Profit&quot;' />
            </column>
            <column caption='Select Year' datatype='integer' default-format='n0;-0' name='[Parameter 2]' param-domain-type='list' role='measure' type='quantitative' value='2017'>
              <calculation class='tableau' formula='2017' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0a9v1y30n0n7ai17qoxhm0c88803'>
            <column caption='PY Sales' datatype='real' default-format='n0,K;-0,K' name='[CY Sales (copy)_1649881534365711]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=([Parameters].[Parameter 2]-1) THEN [Sales]&#13;&#10;END' />
            </column>
            <column caption='CY Profit' datatype='real' default-format='n#,##0,K;-#,##0,K' name='[Calculation_0093797858074624]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 2] THEN [Profit]&#13;&#10;END' />
            </column>
            <column caption='PY Profit' datatype='real' name='[Calculation_0093797858230273]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=([Parameters].[Parameter 2]-1) THEN [Profit]&#13;&#10;END' />
            </column>
            <column caption='% Diff Profit' datatype='real' default-format='p0.0%' name='[Calculation_0093797859991554]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Calculation_0093797858074624])-SUM([Calculation_0093797858230273]))/ SUM([Calculation_0093797858230273])' />
            </column>
            <column caption='Min/Max Profit' datatype='real' name='[Calculation_0093797868683267]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF  SUM([Calculation_0093797858074624])=WINDOW_MAX(SUM([Calculation_0093797858074624]))&#13;&#10;THEN SUM([Calculation_0093797858074624])&#13;&#10;ELSEIF SUM([Calculation_0093797858074624])=WINDOW_MIN(SUM([Calculation_0093797858074624]))&#13;&#10;THEN SUM([Calculation_0093797858074624])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='CY Quantity' datatype='integer' name='[Calculation_0093797995630601]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 2] THEN [Quantity]&#13;&#10;END' />
            </column>
            <column caption='PY Quantity' datatype='integer' name='[Calculation_0093797995806730]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 2]-1 THEN [Quantity]&#13;&#10;END' />
            </column>
            <column caption='Min/Max Quantity' datatype='integer' name='[Calculation_0093797995950091]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF  SUM([Calculation_0093797995630601])=WINDOW_MAX(SUM([Calculation_0093797995630601]))&#13;&#10;THEN SUM([Calculation_0093797995630601])&#13;&#10;ELSEIF SUM([Calculation_0093797995630601])=WINDOW_MIN(SUM([Calculation_0093797995630601]))&#13;&#10;THEN SUM([Calculation_0093797995630601])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='% Diff Quantity' datatype='real' name='[Calculation_0093797996240908]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Calculation_0093797995630601])-SUM([Calculation_0093797995806730]))/ SUM([Calculation_0093797995806730])' />
            </column>
            <column caption='CY Customers' datatype='integer' name='[Calculation_0093798279786516]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(IF YEAR([Order Date])=[Parameters].[Parameter 2] THEN [Customer ID]&#13;&#10;END)' />
            </column>
            <column caption='PY Customers' datatype='integer' name='[Calculation_0093798280167445]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(IF YEAR([Order Date])=[Parameters].[Parameter 2]-1 THEN [Customer ID]&#13;&#10;END)' />
            </column>
            <column caption='% Diff Customers' datatype='real' name='[Calculation_0093798280798230]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(([Calculation_0093798279786516])-([Calculation_0093798280167445]))/([Calculation_0093798280167445])' />
            </column>
            <column caption='Min/Max Customers' datatype='integer' name='[Calculation_0093798283849751]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF  ([Calculation_0093798279786516])=WINDOW_MAX(([Calculation_0093798279786516]))&#13;&#10;THEN ([Calculation_0093798279786516])&#13;&#10;ELSEIF ([Calculation_0093798279786516])=WINDOW_MIN(([Calculation_0093798279786516]))&#13;&#10;THEN ([Calculation_0093798279786516])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='CY Sales Per Customer' datatype='real' name='[Calculation_1157850779025408]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_1649881533546510])/([Calculation_0093798279786516])' />
            </column>
            <column caption='PY Sales Per Customer' datatype='real' name='[Calculation_1157850779320321]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([CY Sales (copy)_1649881534365711]))/[Calculation_0093798280167445]' />
            </column>
            <column caption='% Diff Sales Per Customer' datatype='real' name='[Calculation_1157850780254210]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([Calculation_1157850779025408]-[Calculation_1157850779320321])/[Calculation_1157850779320321]' />
            </column>
            <column caption='PY Orders' datatype='integer' name='[Calculation_1157850782384133]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(IF YEAR([Order Date])=[Parameters].[Parameter 2]-1 THEN [Order ID]&#13;&#10;END)' />
            </column>
            <column caption='CY Orders' datatype='integer' name='[Calculation_1157850782580742]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(IF YEAR([Order Date])=[Parameters].[Parameter 2] THEN [Order ID]&#13;&#10;END)' />
            </column>
            <column caption='%Diff Orders' datatype='real' name='[Calculation_1157850782752775]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(([Calculation_1157850782580742])-([Calculation_1157850782384133]))/([Calculation_1157850782384133])' />
            </column>
            <column caption='Min/Max Orders' datatype='integer' name='[Calculation_1157850783719432]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF  ([Calculation_1157850782580742])=WINDOW_MAX(([Calculation_1157850782580742]))&#13;&#10;THEN ([Calculation_1157850782580742])&#13;&#10;ELSEIF ([Calculation_1157850782580742])=WINDOW_MIN(([Calculation_1157850782580742]))&#13;&#10;THEN ([Calculation_1157850782580742])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Min/ Max Sales Per Customer' datatype='real' name='[Calculation_1157850794074125]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF  ([Calculation_1157850779025408])=WINDOW_MAX(([Calculation_1157850779025408]))&#13;&#10;THEN ([Calculation_1157850779025408])&#13;&#10;ELSEIF ([Calculation_1157850779025408])=WINDOW_MIN(([Calculation_1157850779025408]))&#13;&#10;THEN ([Calculation_1157850779025408])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Total Customers' datatype='integer' name='[Calculation_1649881373405184]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([Customer ID])' />
            </column>
            <column caption='Profit Ratio' datatype='real' name='[Calculation_1649881373667329]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Profit]/[Sales] )' />
            </column>
            <column caption='Running total Sales' datatype='real' name='[Calculation_1649881373941762]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='RUNNING_SUM(SUM([Sales]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Customer Growth' datatype='integer' name='[Calculation_1649881374420995]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF FIRST()=0 THEN COUNTD([Customer ID])END'>
                <table-calc ordering-type='Rows' />
