            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0a9v1y30n0n7ai17qoxhm0c88803'>
            <column caption='CY Profit' datatype='real' default-format='n#,##0,K;-#,##0,K' name='[Calculation_0093797858074624]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 2] THEN [Profit]&#13;&#10;END' />
            </column>
            <column caption='PY Profit' datatype='real' name='[Calculation_0093797858230273]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=([Parameters].[Parameter 2]-1) THEN [Profit]&#13;&#10;END' />
            </column>
            <column caption='% Diff Profit' datatype='real' default-format='p0.0%' name='[Calculation_0093797859991554]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Calculation_0093797858074624])-SUM([Calculation_0093797858230273]))/ SUM([Calculation_0093797858230273])' />
            </column>
            <column caption='Min/Max Profit' datatype='real' name='[Calculation_0093797868683267]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF  SUM([Calculation_0093797858074624])=WINDOW_MAX(SUM([Calculation_0093797858074624]))&#13;&#10;THEN SUM([Calculation_0093797858074624])&#13;&#10;ELSEIF SUM([Calculation_0093797858074624])=WINDOW_MIN(SUM([Calculation_0093797858074624]))&#13;&#10;THEN SUM([Calculation_0093797858074624])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
