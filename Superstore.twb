              </calculation>
            </column>
            <column caption='Latest Growth Sales' datatype='real' name='[Calculation_1649881494913037]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF LAST() = 0 THEN&#13;&#10;(SUM([Sales]) - LOOKUP(SUM([Sales]), -1))&#13;&#10;/ LOOKUP(SUM([Sales]), -1)&#13;&#10;END'>
